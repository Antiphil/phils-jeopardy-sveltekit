# Auth.js Secret (at least 32 characters)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google OAuth (https://console.cloud.google.com) — optional
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public URL of the app (required in production)
# Local dev: http://localhost:5173
AUTH_URL=https://your-domain.com

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/phils_jeopardy

# Node.js adapter (optional, defaults shown)
# PORT=3000
# HOST=0.0.0.0
# ORIGIN=https://your-domain.com
