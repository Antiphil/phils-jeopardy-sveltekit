# Auth.js Secret (at least 32 characters)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Google OAuth (https://console.cloud.google.com) — optional
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public URL of the app (required in production)
AUTH_URL=https://your-domain.com

# SvelteKit CSRF origin check — must match public URL
ORIGIN=https://your-domain.com

# PostgreSQL connection string
# Docker: use service name "db" as host
DATABASE_URL=postgresql://jeopardy:your-db-password@db:5432/phils_jeopardy

# PostgreSQL password (used by docker-compose for the db container)
POSTGRES_PASSWORD=your-db-password

# Cloudflare Tunnel token
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
